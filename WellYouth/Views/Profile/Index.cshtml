@model WellYouth.Models.ViewModels.Profile.ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<section class="page-section">
    <div class="page-header">
        <div class="page-header__content">
            <span class="page-header__eyebrow"><i class="fas fa-user"></i> Personal overview</span>
            <h1>My profile</h1>
            <p>A simple summary of your health score, logged habits, and recent progress.</p>
        </div>
    </div>

    <div class="grid-dashboard">
        <aside class="surface-card surface-card--accent">
            <div class="profile-identity">
                <div class="avatar-mark"><i class="fas fa-user"></i></div>
                <div class="stack stack-gap-tight">
                    <h2>@Model.User.FullName</h2>
                    <p>@Model.User.Email</p>
                    <span class="pill pill--accent">@Model.User.Age years old</span>
                </div>
            </div>

            <div class="stat-grid section-spacing-top">
                <div class="stat-card">
                    <div class="stat-card__value">@Model.User.HealthScore</div>
                    <p>Health score</p>
                </div>
                <div class="stat-card">
                    <div class="stat-card__value">@Model.HabitCompletionCount</div>
                    <p>Habits logged</p>
                </div>
            </div>
        </aside>

        <div class="stack">
            <section class="surface-card">
                <h2 class="section-title">Health suggestions</h2>
                <div class="list-clean">
                    @foreach (var suggestion in Model.Suggestions)
                    {
                        <div class="list-item">
                            <p>@suggestion</p>
                        </div>
                    }
                </div>
            </section>

            <section class="surface-card">
                <div class="split section-title">
                    <h2>Recent points earned</h2>
                    <span class="text-muted">Latest scoring events</span>
                </div>

                @if (Model.RecentScores.Any())
                {
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Reason</th>
                                    <th>Points</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var score in Model.RecentScores)
                                {
                                    <tr>
                                        <td>@score.ScoreDate.ToShortDateString()</td>
                                        <td>@score.Reason</td>
                                        <td><strong>+@score.Score</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <h3>No score history yet</h3>
                        <p>As you log habits and complete activities, your recent points will appear here.</p>
                    </div>
                }
            </section>

            <section class="surface-card">
                <div class="split section-title">
                    <h2>Specialist requests</h2>
                    <span class="text-muted">History of intent to contact</span>
                </div>

                @if (Model.ContactRequests.Any())
                {
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Specialist</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var request in Model.ContactRequests)
                                {
                                    <tr>
                                        <td><strong>@request.Specialist?.Name</strong></td>
                                        <td>@request.CreatedAt.ToShortDateString()</td>
                                        <td>
                                            <span class="pill pill--@(request.Status == "Pending" ? "primary" : "success")">
                                                @request.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <h3>No requests logged</h3>
                        <p>When you use the "Log Request" feature on the Specialists page, your records will appear here.</p>
                    </div>
                }
            </section>
        </div>
    </div>
</section>
