@model WellYouth.Models.ViewModels.Habits.CreateHabitViewModel
@{
    ViewData["Title"] = "Create Habit";
}

<section class="page-section">
    <div class="page-header">
        <div class="page-header__content">
            <span class="page-header__eyebrow"><i class="fas fa-plus"></i> Add a routine</span>
            <h1>Create a new health habit</h1>
            <p>Choose something realistic. Smaller repeatable actions tend to last longer than aggressive goals.</p>
        </div>
    </div>

    <div class="content-container">
        <div class="surface-card">
            <form asp-action="Create" method="post" class="stack">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <div class="field">
                    <label asp-for="Name" class="field__label"></label>
                    <input asp-for="Name" placeholder="Habit name, such as 15-minute walk" />
                    <span asp-validation-for="Name" class="field-validation-error"></span>
                </div>

                <div class="field">
                    <label asp-for="Description" class="field__label"></label>
                    <textarea asp-for="Description" placeholder="Optional details"></textarea>
                    <span asp-validation-for="Description" class="field-validation-error"></span>
                </div>

                <div class="field">
                    <label asp-for="Category" class="field__label"></label>
                    <select asp-for="Category">
                        <option value="Physical">Physical Health</option>
                        <option value="Mental">Mental Health</option>
                        <option value="Nutrition">Nutrition</option>
                        <option value="Sleep">Sleep Quality</option>
                        <option value="Social">Social Connection</option>
                    </select>
                    <span asp-validation-for="Category" class="field-validation-error"></span>
                </div>

                <div class="field">
                    <label asp-for="TargetFrequency" class="field__label"></label>
                    <input asp-for="TargetFrequency" placeholder="Daily, weekdays, 3 times a week" />
                    <span asp-validation-for="TargetFrequency" class="field-validation-error"></span>
                </div>

                <div class="form-actions">
                    <a asp-action="Index" class="button button--secondary">Cancel</a>
                    <button type="submit" class="button button--primary">Create habit</button>
                </div>
            </form>
        </div>
    </div>
</section>
