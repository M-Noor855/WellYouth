@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="page-section">
    <div class="content-container">
        <div class="surface-card">
            <div class="stack">
                <span class="page-header__eyebrow"><i class="fas fa-triangle-exclamation"></i> Request failed</span>
                <h1>Something went wrong</h1>
                <p>The request could not be completed. Try again or return to a stable page.</p>

                @if (Model.ShowRequestId)
                {
                    <div class="alert alert-danger">
                        Request ID: <code>@Model.RequestId</code>
                    </div>
                }

                <div class="stack">
                    <h2 class="text-size-sm">Development mode note</h2>
                    <p>When the app runs in <strong>Development</strong>, more detailed exception information is available locally.</p>
                </div>
            </div>
        </div>
    </div>
</section>
